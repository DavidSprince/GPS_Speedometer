<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/parent_widget_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_alignParentTop="true">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="D-Route Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="D-ROUTE COCKPIT"
            android:textColor="#94A3B8"
            android:textSize="9sp"
            android:layout_marginStart="6dp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="READY"
            android:textColor="#10B981"
            android:textSize="8sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/badge_background"
            android:paddingHorizontal="6dp"
            android:paddingVertical="1dp" />
    </LinearLayout>

    <!-- Content Split Layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_below="@id/header_layout"
        android:layout_marginTop="6dp">

        <!-- Left Speedometer Section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1.2"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/widget_speed_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0"
                android:textColor="#00F2FE"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KM/H"
                android:textColor="#64748B"
                android:textSize="8.5sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Vertical Accent Divider -->
        <FrameLayout
            android:layout_width="1.2dp"
            android:layout_height="36dp"
            android:background="#1E293B"
            android:layout_marginHorizontal="8dp" />

        <!-- Right Fuel Predictor Section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1.3"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_range_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="13.5"
                android:textColor="#F59E0B"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EST RANGE (KM)"
                android:textColor="#64748B"
                android:textSize="8sp"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ProgressBar
                    android:id="@+id/widget_fuel_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="54dp"
                    android:layout_height="4.5dp"
                    android:max="100"
                    android:progress="40"
                    android:progressDrawable="@drawable/widget_progress_bar" />

                <TextView
                    android:id="@+id/widget_fuel_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="40%"
                    android:textColor="#94A3B8"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginStart="4dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
